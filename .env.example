# ===== Neo4j =====
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=yourStrongPassword
NEO4J_DATABASE=neo4j

# ===== OpenRouter (OpenAI-compatible) =====
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Default model — OpenRouter id for Gemini Flash. Override for LM Studio.
LLM_MODEL=google/gemini-2.5-flash
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=120

# Optional: point at LM Studio (OpenAI compatible). Takes precedence if set.
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_API_KEY=lm-studio

# ===== Embeddings =====
# 'sentence-transformers/all-MiniLM-L6-v2' (local, dim=384) or 'openai' (uses OPENROUTER_*)
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ===== Chunking =====
CHUNK_TOKEN_SIZE=600
CHUNK_OVERLAP=80
CHUNKS_TO_COMBINE=1
MAX_TOKEN_CHUNK_SIZE=20000

# ===== Schema discovery =====
SCHEMA_DISCOVERY_SAMPLE_SIZE=5
SCHEMA_DISCOVERY_MAX_CHARS=12000

# ===== Pipeline =====
INGEST_CONCURRENCY=4
ENABLE_POST_PROCESSING=true
ENABLE_SIMILAR_CHUNKS=true
KNN_MIN_SCORE=0.8

# ===== Flask =====
FLASK_ENV=development
FLASK_HOST=0.0.0.0
FLASK_PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173

# ===== LLM call audit log =====
# SQLite file (created on first write). Path is relative to the repo root.
LLM_LOG_DB_PATH=backend/data/llm_calls.db
LLM_LOG_ENABLED=true
LLM_LOG_MAX_BODY_CHARS=200000

# ===== Domain =====
DOMAIN=medical
